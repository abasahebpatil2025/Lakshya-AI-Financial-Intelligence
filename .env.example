# --- External APIs ---
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
POLYGON_API_KEY==your_polygon_api_key_here

# --- AWS Configuration ---
# The code uses local AWS profiles (~/.aws/credentials). 
# Ensure you have 'aws configure' set up.
AWS_PROFILE=default
AWS_REGION=us-east-1

# --- Operational Settings ---
# Set to 'false' to use real AWS Bedrock and APIs
MOCK_MODE=true

# --- Logging & Cache ---
LOG_LEVEL=INFO
LOG_FILE=logs/lakshya_ai.log
STOCK_DATA_CACHE_TTL=300

# --- Email Settings ---
# Use Google App Passwords for secure SMTP access
SENDER_EMAIL=your_email@gmail.com
APP_PASSWORD=your_16_digit_app_password_here